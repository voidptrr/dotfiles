scriptencoding utf-8

set nocompatible
set ignorecase
set smartcase
set number
set tabstop=4
set shiftwidth=4
set expandtab
set mouse=a

set autoindent
set backspace=indent,start,eol

set nobackup
set nowritebackup

set termguicolors
set background=dark

set noemoji

set path+=**

set splitbelow
set splitright
